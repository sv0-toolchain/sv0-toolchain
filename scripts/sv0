#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SV0C="$ROOT/sv0c"
SV0VM="$ROOT/sv0vm"
SV0DOC="$ROOT/sv0doc"
SV0_MCP="$ROOT/sv0-mcp"

# shellcheck disable=SC1091
source "$ROOT/lib/shell/common.sh"

usage() {
  cat >&2 <<EOF
usage: sv0 <command> [args]

  check              compile sv0c (CM) and sv0vm (use) — fast smoke compile
  build              alias for check
  test               sv0c units; .sv0 block-comment guard; sv0doc baseline; task/*.Rmd YAML lint;
                       sv0vm bytecode tests; C + VM integration; bootstrap .sv0 on VM; stage0 golden
                       C vs SML emit (when lib/golden/stage0/<stem>.c exists); Markdown doctests — see
                       task/sv0-toolchain-milestone-2-prep.Rmd for exact order
  test-guards        Python only: block-comment nesting, sv0doc baseline paths, task/*.Rmd YAML lint
                       (no SML — use after editing task/*.Rmd, sv0doc, or .sv0 comments)
  test-mcp           sv0-mcp pytest via uv (skips if uv not installed)
  doc                generate build/sv0-toolchain-doc/index.md; verify sv0doc + sv0-mcp paths
  doctest            run Markdown sv0 doctests only (see task/sv0-toolchain-milestone-2-prep/doctests.md)
  fmt                format .sv0 sources (whitespace) + shell fmt (see fmt-shell)
  fmt-shell          bash -n on shell scripts; shfmt -w if shfmt is in PATH
  bootstrap-build    VM-compile programs listed in sv0c/lib/bootstrap-sources.list (fallback: lib/*.sv0)
  emit-c <rel>       print C for one .sv0 (path relative to sv0c/; uses make heap + SML bootstrap)
  self-host-capture-stage0 <rel>  write C to build/self-host-compare/stage0/<stem>.c (stage-0 snapshot)
  self-host-compare <stem>  diff stage0 vs stage1 C for <stem> when both files exist
  self-host-check-golden  diff bootstrap C vs lib/golden/stage0/<stem>.c (same rules as sv0 test)
  integration-vm     VM pipeline integration tests (task script)
  vm-compile <rel>   sv0c --target=vm; path relative to sv0c/
  vm-run <file.sv0b> run bytecode via sv0vm/scripts/run_sv0b.sml
  repl               interactive line-at-a-time eval via VM (i32 expr or println(\"...\"))
  ci                 check + full ./scripts/sv0 test (no sv0-mcp; same as \`make ci\`)
  ci-all             after ci, run test-mcp when uv is available (full toolchain smoke)

EOF
}

require_sml() {
  sv0_require_cmd sml
}

sml_log_check() {
  local label="$1"
  local log="$2"
  if grep -q 'Error:' "$log"; then
    tail -50 "$log"
    rm -f "$log"
    sv0_fail "$label: SML compile errors"
  fi
  rm -f "$log"
}

check_sv0c() {
  require_sml
  local log
  log="$(mktemp)"
  if ! ( cd "$SV0C" && echo 'CM.make "sources.cm";' | sml >"$log" 2>&1 ); then
    tail -50 "$log"
    rm -f "$log"
    sv0_fail "sv0c: sml exited non-zero"
  fi
  sml_log_check "sv0c" "$log"
  sv0_ok "sv0c: sources.cm"
}

check_sv0vm() {
  require_sml
  local log
  log="$(mktemp)"
  if ! ( cd "$SV0VM" && echo 'use "src/main.sml";' | sml >"$log" 2>&1 ); then
    tail -50 "$log"
    rm -f "$log"
    sv0_fail "sv0vm: sml exited non-zero"
  fi
  sml_log_check "sv0vm" "$log"
  sv0_ok "sv0vm: interpreter loads"
}

run_check() {
  check_sv0c
  check_sv0vm
}

# Python regression guards also run inside run_test; exposed as `sv0 test-guards` for fast iteration.
run_python_guards() {
  local label="${1:-sv0}"
  local ec=0
  sv0_require_cmd python3
  sv0_info "$label: .sv0 block-comment nesting guard"
  if ! python3 "$ROOT/scripts/check_sv0_block_comment_nesting.py"; then
    ec=1
  fi
  sv0_info "$label: sv0doc baseline (milestone 0 paths)"
  if ! python3 "$ROOT/scripts/verify_sv0doc_baseline.py" --root "$ROOT"; then
    ec=1
  fi
  sv0_info "$label: task/*.Rmd YAML front matter (graph-safe keys)"
  if ! python3 "$ROOT/scripts/verify_task_rmd_frontmatter.py" --root "$ROOT"; then
    ec=1
  fi
  return "$ec"
}

run_test_guards() {
  if ! run_python_guards "sv0 test-guards"; then
    sv0_fail "sv0 test-guards: one or more Python checks failed"
  fi
  sv0_ok "sv0 test-guards: block-comment guard + sv0doc baseline + task YAML"
}

run_test() {
  local ec=0
  (cd "$SV0C" && make test) || ec=1
  if ! run_python_guards "sv0 test"; then
    ec=1
  fi
  require_sml
  if ! (cd "$SV0VM" && echo 'use "src/main.sml"; use "test/bytecode_test.sml";' | sml >/dev/null); then
    ec=1
  fi
  sv0_info "sv0 test: C backend integration (sv0c)"
  if ! bash "$ROOT/task/sv0c-milestone-1/02-integration-test.sh"; then
    ec=1
  fi
  sv0_info "sv0 test: VM pipeline integration"
  if ! bash "$ROOT/task/sv0vm-milestone-2/02-integration-test.sh"; then
    ec=1
  fi
  sv0_info "sv0 test: bootstrap-in-sv0 programs on VM"
  if ! run_bootstrap_build; then
    ec=1
  fi
  sv0_info "sv0 test: stage0 C vs lib/golden/stage0 (when present)"
  if ! run_self_host_stage0_golden; then
    ec=1
  fi
  sv0_info "sv0 test: Markdown doctests"
  if ! run_doctests; then
    ec=1
  fi
  if [[ "$ec" -ne 0 ]]; then
    sv0_fail "sv0 test: one or more stages failed (exit $ec)"
  fi
  sv0_ok "sv0 test: units + C integration + VM integration + bootstrap-in-sv0 + stage0 golden + block-comment guard + sv0doc baseline + task YAML + doctests"
}

run_doctests() {
  sv0_require_cmd python3
  python3 "$ROOT/scripts/sv0_doctest.py" --root "$ROOT" \
    "$ROOT/task/sv0-toolchain-milestone-2-prep/doctests.md"
}

# Sets BOOTSTRAP_SV0_RELS (paths relative to sv0c/) for bootstrap-build and stage0 golden checks.
bootstrap_fill_sv0_paths() {
  BOOTSTRAP_SV0_RELS=()
  local list=""
  if [[ -f "$SV0C/lib/bootstrap-sources.list" ]]; then
    list="$SV0C/lib/bootstrap-sources.list"
  fi
  local line
  if [[ -n "$list" ]]; then
    while IFS= read -r line || [[ -n "$line" ]]; do
      [[ "$line" =~ ^[[:space:]]*# ]] && continue
      [[ -z "${line//[[:space:]]/}" ]] && continue
      BOOTSTRAP_SV0_RELS+=("$line")
    done <"$list"
  fi
  if ((${#BOOTSTRAP_SV0_RELS[@]} == 0)); then
    shopt -s nullglob
    local f
    for f in "$SV0C"/lib/*.sv0; do
      BOOTSTRAP_SV0_RELS+=("lib/$(basename "$f")")
    done
    shopt -u nullglob
  fi
}

_self_host_stage0_heap_ready() {
  (cd "$SV0C" && make heap >/dev/null 2>&1)
}

# Emit C for one .sv0 via SML heap image; write to $2. Requires heap ready. Returns 0 on success.
_self_host_stage0_emit_c_to() {
  local rel="${1:?}"
  local out="${2:?}"
  local log
  log="$(mktemp)"
  if [[ ! -f "$SV0C/$rel" ]]; then
    rm -f "$log"
    return 1
  fi
  set +e
  (cd "$SV0C" && sml "@SMLload=build/sv0c" "$rel" >"$out" 2>"$log")
  local sml_ec=$?
  set -e
  if [[ "$sml_ec" -ne 0 ]] || grep -q 'Error:' "$log"; then
    tail -30 "$log" >&2
    rm -f "$log"
    return 1
  fi
  rm -f "$log"
  if ! grep -q '#include' "$out"; then
    echo "self-host: emitted file missing #include: $out" >&2
    return 1
  fi
  return 0
}

run_self_host_stage0_golden() {
  require_sml
  bootstrap_fill_sv0_paths
  local -a rel_paths=("${BOOTSTRAP_SV0_RELS[@]}")
  if ((${#rel_paths[@]} == 0)); then
    sv0_info "self-host stage0 golden: skipped (no bootstrap-in-sv0 sources)"
    return 0
  fi
  local rel stem golden n=0
  for rel in "${rel_paths[@]}"; do
    stem=$(basename "$rel" .sv0)
    golden="$SV0C/lib/golden/stage0/${stem}.c"
    if [[ -f "$golden" ]]; then
      n=$((n + 1))
    fi
  done
  if [[ "$n" -eq 0 ]]; then
    sv0_info "self-host stage0 golden: no lib/golden/stage0/<stem>.c for list entries; skipped"
    return 0
  fi
  if ! _self_host_stage0_heap_ready; then
    sv0_fail "self-host stage0 golden: sv0c make heap failed"
  fi
  local tmp d
  for rel in "${rel_paths[@]}"; do
    stem=$(basename "$rel" .sv0)
    golden="$SV0C/lib/golden/stage0/${stem}.c"
    if [[ ! -f "$golden" ]]; then
      continue
    fi
    tmp="$(mktemp)"
    if ! _self_host_stage0_emit_c_to "$rel" "$tmp"; then
      rm -f "$tmp"
      sv0_fail "self-host stage0 golden: emit failed for $rel"
    fi
    set +e
    diff -u "$golden" "$tmp"
    d=$?
    set -e
    rm -f "$tmp"
    if [[ "$d" -ne 0 ]]; then
      sv0_fail "self-host stage0 golden: ${stem}.c differs from $golden (refresh golden after intentional C-backend change)"
    fi
  done
  sv0_ok "self-host stage0 golden: $n file(s) match bootstrap C output"
  return 0
}

run_bootstrap_build() {
  require_sml
  mkdir -p "$SV0C/build/vm"
  local rel stem sv0b out log
  bootstrap_fill_sv0_paths
  local -a rel_paths=("${BOOTSTRAP_SV0_RELS[@]}")
  if ((${#rel_paths[@]} == 0)); then
    sv0_warn "bootstrap-build: no lib/bootstrap-sources.list and no top-level lib/*.sv0"
    sv0_ok "bootstrap-build: skipped (no sources)"
    return 0
  fi
  for rel in "${rel_paths[@]}"; do
    stem=$(basename "$rel" .sv0)
    sv0b="$SV0C/build/vm/${stem}.sv0b"
    if [[ ! -f "$SV0C/$rel" ]]; then
      echo "bootstrap-build: missing file $SV0C/$rel" >&2
      return 1
    fi
    log="$(mktemp)"
    if ! (cd "$SV0C" && echo "CM.make \"sources.cm\"; Main.main ((), [\"--target=vm\", \"$rel\"]);" | sml >"$log" 2>&1); then
      tail -30 "$log"
      rm -f "$log"
      return 1
    fi
    if grep -q 'Error:' "$log"; then
      tail -30 "$log"
      rm -f "$log"
      return 1
    fi
    rm -f "$log"
    if [[ ! -f "$sv0b" ]]; then
      echo "bootstrap-build: missing $sv0b (for $rel)" >&2
      return 1
    fi
    out="$(cd "$SV0VM" && SV0B="$sv0b" sml < scripts/run_sv0b.sml 2>&1)" || true
    if ! echo "$out" | grep -q "vm_exit:0"; then
      echo "$out" | tail -20
      return 1
    fi
  done
  sv0_ok "bootstrap-build: all listed (or top-level lib/*.sv0) programs passed on VM"
  return 0
}

run_emit_c() {
  local rel="${1:-}"
  if [[ -z "$rel" ]]; then
    echo "usage: sv0 emit-c <path-relative-to-sv0c/>" >&2
    exit 1
  fi
  require_sml
  if [[ ! -f "$SV0C/$rel" ]]; then
    sv0_fail "emit-c: not found: $SV0C/$rel"
  fi
  if ! (cd "$SV0C" && make heap >/dev/null 2>&1); then
    sv0_fail "emit-c: sv0c make heap failed"
  fi
  (cd "$SV0C" && sml "@SMLload=build/sv0c" "$rel")
}

run_self_host_capture_stage0() {
  local rel="${1:-}"
  if [[ -z "$rel" ]]; then
    echo "usage: sv0 self-host-capture-stage0 <path-relative-to-sv0c/>" >&2
    exit 1
  fi
  local stem
  stem=$(basename "$rel" .sv0)
  local outdir="$ROOT/build/self-host-compare/stage0"
  mkdir -p "$outdir"
  local out="$outdir/${stem}.c"
  require_sml
  if [[ ! -f "$SV0C/$rel" ]]; then
    sv0_fail "self-host-capture-stage0: not found: $SV0C/$rel"
  fi
  if ! _self_host_stage0_heap_ready; then
    sv0_fail "self-host-capture-stage0: sv0c make heap failed"
  fi
  if ! _self_host_stage0_emit_c_to "$rel" "$out"; then
    sv0_fail "self-host-capture-stage0: compile failed for $rel"
  fi
  sv0_ok "self-host-capture-stage0: wrote $out"
}

run_self_host_compare() {
  local stem="${1:-}"
  if [[ -z "$stem" ]]; then
    echo "usage: sv0 self-host-compare <stem>   (e.g. span_core for span_core.c)" >&2
    exit 1
  fi
  local s0="$ROOT/build/self-host-compare/stage0/${stem}.c"
  local s1="$ROOT/build/self-host-compare/stage1/${stem}.c"
  if [[ ! -f "$s0" ]]; then
    sv0_fail "self-host-compare: missing stage0 file $s0 (run self-host-capture-stage0 first)"
  fi
  if [[ ! -f "$s1" ]]; then
    sv0_info "self-host-compare: stage1 missing $s1 — nothing to diff yet"
    return 0
  fi
  set +e
  diff -u "$s0" "$s1"
  local d=$?
  set -e
  if [[ "$d" -eq 0 ]]; then
    sv0_ok "self-host-compare: $stem stage0 and stage1 C are identical"
  else
    sv0_fail "self-host-compare: $stem differs between stage0 and stage1"
  fi
}

run_test_mcp() {
  sv0_require_dir "$SV0_MCP"
  if command -v uv >/dev/null 2>&1; then
    (cd "$SV0_MCP" && uv sync --all-extras)
    (cd "$SV0_MCP" && uv run pytest tests/ -q)
    sv0_ok "sv0-mcp: pytest"
  else
    sv0_info "uv not in PATH; skipped sv0-mcp tests (install uv or run from sv0-mcp/)"
  fi
}

run_doc() {
  sv0_require_cmd python3
  sv0_require_dir "$SV0DOC"
  sv0_require_file "$SV0DOC/README.md"
  sv0_require_file "$SV0DOC/bytecode/format.md"
  sv0_require_file "$SV0DOC/bytecode/instructions.md"
  sv0_require_dir "$SV0_MCP"
  sv0_require_file "$SV0_MCP/README.md"
  python3 "$ROOT/scripts/gen_sv0_doc.py" --root "$ROOT"
  sv0_ok "sv0 doc: generated build/sv0-toolchain-doc/index.md; sv0doc + sv0-mcp paths OK"
}

run_fmt_sv0() {
  sv0_require_cmd python3
  python3 "$ROOT/scripts/fmt_sv0.py" "$SV0C" "$SV0VM"
  sv0_ok "fmt: .sv0 whitespace normalization under sv0c/ and sv0vm/"
}

run_fmt() {
  run_fmt_sv0
  run_fmt_shell
}

run_fmt_shell() {
  local f
  local fmt_targets=(
    "$ROOT/scripts/sv0"
    "$ROOT/scripts/ci-install-smlnj.sh"
    "$ROOT/lib/shell/common.sh"
    "$ROOT/lib/sml/build-helpers.sh"
    "$ROOT/task/sv0vm-milestone-2/01-verify-setup.sh"
    "$ROOT/task/sv0vm-milestone-2/02-integration-test.sh"
    "$ROOT/task/sv0c-milestone-1/01-verify-sml-setup.sh"
    "$ROOT/task/sv0c-milestone-1/02-integration-test.sh"
    "$ROOT/task/sv0-toolchain-workspace/01-verify-submodules.sh"
    "$ROOT/task/sv0-mcp-milestone-0/01-verify-package.sh"
  )
  for f in "${fmt_targets[@]}"; do
    [[ -f "$f" ]] || continue
    bash -n "$f" || sv0_fail "bash -n failed: $f"
  done
  if command -v shfmt >/dev/null 2>&1; then
    local existing=()
    for f in "${fmt_targets[@]}"; do
      [[ -f "$f" ]] && existing+=("$f")
    done
    if ((${#existing[@]} > 0)); then
      shfmt -i 2 -w "${existing[@]}"
    fi
    sv0_ok "shfmt applied"
  else
    sv0_info "shfmt not installed; skipped write-format"
  fi
  sv0_ok "fmt-shell: bash syntax OK"
}

run_ci() {
  run_check
  run_test
  sv0_ok "ci: SML-only (check + full sv0 test harness) passed"
}

run_ci_all() {
  run_ci
  run_test_mcp
  sv0_ok "ci-all: SML ci + sv0-mcp (pytest when uv is available)"
}

run_repl() {
  require_sml
  mkdir -p "$SV0C/build/vm"
  local src="$SV0C/build/repl_line.sv0"
  echo "sv0 repl (bytecode VM). Enter an i32 expression (e.g. 2 + 2) or a println(\"...\") call." >&2
  echo "main's exit code is printed as the expression result. :q or EOF quits." >&2
  while true; do
    read -r -p "> " line || {
      echo >&2
      break
    }
    [[ -z "${line//[[:space:]]/}" ]] && continue
    case "$line" in
      :q | :quit) break ;;
    esac
    if [[ "$line" =~ ^[[:space:]]*println\( ]]; then
      local stmt="$line"
      [[ "$stmt" != *';' ]] && stmt="${stmt};"
      cat >"$src" <<EOF
fn main() -> unit {
  ${stmt}
}
EOF
    else
      cat >"$src" <<EOF
fn main() -> i32 {
  return (${line});
}
EOF
    fi
    local log
    log="$(mktemp)"
    if ! (cd "$SV0C" && echo "CM.make \"sources.cm\"; Main.main ((), [\"--target=vm\", \"build/repl_line.sv0\"]);" | sml >"$log" 2>&1); then
      echo "compile error:" >&2
      tail -20 "$log" >&2
      rm -f "$log"
      continue
    fi
    if grep -q 'Error:' "$log"; then
      echo "compile error:" >&2
      tail -20 "$log" >&2
      rm -f "$log"
      continue
    fi
    rm -f "$log"
    local sv0b="$SV0C/build/vm/repl_line.sv0b"
    if [[ ! -f "$sv0b" ]]; then
      echo "no bytecode emitted" >&2
      continue
    fi
    local out
    out="$(cd "$SV0VM" && SV0B="$sv0b" sml < scripts/run_sv0b.sml 2>&1)" || true
    local ev
    ev="$(echo "$out" | grep -E '^vm_exit:' | tail -1 | sed 's/^vm_exit://')"
    echo "$out" | awk '/^SV0VM_RUN_BEGIN$/ {p=1; next} /^vm_exit:/ {p=0; next} p && !/^val exitCode =/ {print}' || true
    if [[ -n "$ev" ]]; then
      echo "=> exit ${ev}" >&2
    fi
  done
}

cmd="${1:-}"
shift || true

case "$cmd" in
  check|build)
    run_check
    ;;
  test)
    run_test
    ;;
  test-guards)
    run_test_guards
    ;;
  test-mcp)
    run_test_mcp
    ;;
  doc)
    run_doc
    ;;
  doctest)
    run_doctests
    ;;
  fmt)
    run_fmt
    ;;
  fmt-shell)
    run_fmt_shell
    ;;
  bootstrap-build)
    run_bootstrap_build || exit 1
    ;;
  emit-c)
    rel="${1:-}"
    if [[ -z "$rel" ]]; then usage; exit 1; fi
    run_emit_c "$rel"
    ;;
  self-host-capture-stage0)
    rel="${1:-}"
    if [[ -z "$rel" ]]; then usage; exit 1; fi
    run_self_host_capture_stage0 "$rel"
    ;;
  self-host-compare)
    stem="${1:-}"
    if [[ -z "$stem" ]]; then usage; exit 1; fi
    run_self_host_compare "$stem"
    ;;
  self-host-check-golden)
    run_self_host_stage0_golden || exit 1
    ;;
  integration-vm)
    bash "$ROOT/task/sv0vm-milestone-2/02-integration-test.sh"
    ;;
  vm-compile)
    rel="${1:-}"
    if [[ -z "$rel" ]]; then usage; exit 1; fi
    (cd "$SV0C" && echo "CM.make \"sources.cm\"; Main.main ((), [\"--target=vm\", \"$rel\"]);" | sml)
    ;;
  vm-run)
    sv0b="${1:-}"
    if [[ -z "$sv0b" ]]; then usage; exit 1; fi
    (cd "$SV0VM" && SV0B="$sv0b" sml < scripts/run_sv0b.sml)
    ;;
  repl)
    run_repl
    ;;
  ci)
    run_ci
    ;;
  ci-all)
    run_ci_all
    ;;
  ""|-h|--help)
    usage
    exit 0
    ;;
  *)
    echo "sv0: unknown command: $cmd" >&2
    usage
    exit 1
    ;;
esac
