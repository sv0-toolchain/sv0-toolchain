#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SV0C="$ROOT/sv0c"
SV0VM="$ROOT/sv0vm"
SV0DOC="$ROOT/sv0doc"
SV0_MCP="$ROOT/sv0-mcp"

# shellcheck disable=SC1091
source "$ROOT/lib/shell/common.sh"

usage() {
  cat >&2 <<EOF
usage: sv0 <command> [args]

  check              compile sv0c (CM) and sv0vm (use) — fast smoke compile
  build              alias for check
  test               unified: sv0c + sv0vm units, C + VM integration, rewrite/*.sv0, doctests
  test-mcp           sv0-mcp pytest via uv (skips if uv not installed)
  doc                generate build/sv0-toolchain-doc/index.md; verify sv0doc + sv0-mcp paths
  doctest            run Markdown sv0 doctests only (see task/sv0-toolchain-milestone-2-prep/doctests.md)
  fmt                format .sv0 sources (whitespace) + shell fmt (see fmt-shell)
  fmt-shell          bash -n on shell scripts; shfmt -w if shfmt is in PATH
  rewrite-build      compile sv0c/rewrite/*.sv0 to bytecode and run on sv0vm (exit 0)
  integration-vm     VM pipeline integration tests (task script)
  vm-compile <rel>   sv0c --target=vm; path relative to sv0c/
  vm-run <file.sv0b> run bytecode via sv0vm/scripts/run_sv0b.sml
  repl               interactive line-at-a-time eval via VM (i32 expr or println(\"...\"))
  ci                 SML-only: check + test + integration-vm (no sv0-mcp; same as \`make ci\`)
  ci-all             after ci, run test-mcp when uv is available (full toolchain smoke)

EOF
}

require_sml() {
  sv0_require_cmd sml
}

sml_log_check() {
  local label="$1"
  local log="$2"
  if grep -q 'Error:' "$log"; then
    tail -50 "$log"
    rm -f "$log"
    sv0_fail "$label: SML compile errors"
  fi
  rm -f "$log"
}

check_sv0c() {
  require_sml
  local log
  log="$(mktemp)"
  if ! ( cd "$SV0C" && echo 'CM.make "sources.cm";' | sml >"$log" 2>&1 ); then
    tail -50 "$log"
    rm -f "$log"
    sv0_fail "sv0c: sml exited non-zero"
  fi
  sml_log_check "sv0c" "$log"
  sv0_ok "sv0c: sources.cm"
}

check_sv0vm() {
  require_sml
  local log
  log="$(mktemp)"
  if ! ( cd "$SV0VM" && echo 'use "src/main.sml";' | sml >"$log" 2>&1 ); then
    tail -50 "$log"
    rm -f "$log"
    sv0_fail "sv0vm: sml exited non-zero"
  fi
  sml_log_check "sv0vm" "$log"
  sv0_ok "sv0vm: interpreter loads"
}

run_check() {
  check_sv0c
  check_sv0vm
}

run_test() {
  local ec=0
  (cd "$SV0C" && make test) || ec=1
  require_sml
  if ! (cd "$SV0VM" && echo 'use "src/main.sml"; use "test/bytecode_test.sml";' | sml >/dev/null); then
    ec=1
  fi
  sv0_info "sv0 test: C backend integration (sv0c)"
  if ! bash "$ROOT/task/sv0c-milestone-1/02-integration-test.sh"; then
    ec=1
  fi
  sv0_info "sv0 test: VM pipeline integration"
  if ! bash "$ROOT/task/sv0vm-milestone-2/02-integration-test.sh"; then
    ec=1
  fi
  sv0_info "sv0 test: rewrite/*.sv0 on VM"
  if ! run_rewrite_build; then
    ec=1
  fi
  sv0_info "sv0 test: Markdown doctests"
  if ! run_doctests; then
    ec=1
  fi
  if [[ "$ec" -ne 0 ]]; then
    sv0_fail "sv0 test: one or more stages failed (exit $ec)"
  fi
  sv0_ok "sv0 test: units + C integration + VM integration + rewrite + doctests"
}

run_doctests() {
  sv0_require_cmd python3
  python3 "$ROOT/scripts/sv0_doctest.py" --root "$ROOT" \
    "$ROOT/task/sv0-toolchain-milestone-2-prep/doctests.md"
}

run_rewrite_build() {
  require_sml
  mkdir -p "$SV0C/build/vm"
  shopt -s nullglob
  local f rel stem sv0b out log
  local rw=("$SV0C"/rewrite/*.sv0)
  if ((${#rw[@]} == 0)); then
    sv0_warn "rewrite-build: no sv0c/rewrite/*.sv0 files"
    sv0_ok "rewrite-build: skipped (no sources)"
    return 0
  fi
  for f in "${rw[@]}"; do
    rel="rewrite/$(basename "$f")"
    stem=$(basename "$f" .sv0)
    sv0b="$SV0C/build/vm/${stem}.sv0b"
    log="$(mktemp)"
    if ! (cd "$SV0C" && echo "CM.make \"sources.cm\"; Main.main ((), [\"--target=vm\", \"$rel\"]);" | sml >"$log" 2>&1); then
      tail -30 "$log"
      rm -f "$log"
      return 1
    fi
    if grep -q 'Error:' "$log"; then
      tail -30 "$log"
      rm -f "$log"
      return 1
    fi
    rm -f "$log"
    if [[ ! -f "$sv0b" ]]; then
      echo "rewrite-build: missing $sv0b (for $rel)" >&2
      return 1
    fi
    out="$(cd "$SV0VM" && SV0B="$sv0b" sml < scripts/run_sv0b.sml 2>&1)" || true
    if ! echo "$out" | grep -q "vm_exit:0"; then
      echo "$out" | tail -20
      return 1
    fi
  done
  sv0_ok "rewrite-build: all sv0c/rewrite/*.sv0 passed on VM"
  return 0
}

run_test_mcp() {
  sv0_require_dir "$SV0_MCP"
  if command -v uv >/dev/null 2>&1; then
    (cd "$SV0_MCP" && uv sync --all-extras)
    (cd "$SV0_MCP" && uv run pytest tests/ -q)
    sv0_ok "sv0-mcp: pytest"
  else
    sv0_info "uv not in PATH; skipped sv0-mcp tests (install uv or run from sv0-mcp/)"
  fi
}

run_doc() {
  sv0_require_cmd python3
  sv0_require_dir "$SV0DOC"
  sv0_require_file "$SV0DOC/README.md"
  sv0_require_file "$SV0DOC/bytecode/format.md"
  sv0_require_file "$SV0DOC/bytecode/instructions.md"
  sv0_require_dir "$SV0_MCP"
  sv0_require_file "$SV0_MCP/README.md"
  python3 "$ROOT/scripts/gen_sv0_doc.py" --root "$ROOT"
  sv0_ok "sv0 doc: generated build/sv0-toolchain-doc/index.md; sv0doc + sv0-mcp paths OK"
}

run_fmt_sv0() {
  sv0_require_cmd python3
  python3 "$ROOT/scripts/fmt_sv0.py" "$SV0C" "$SV0VM"
  sv0_ok "fmt: .sv0 whitespace normalization under sv0c/ and sv0vm/"
}

run_fmt() {
  run_fmt_sv0
  run_fmt_shell
}

run_fmt_shell() {
  local f
  local fmt_targets=(
    "$ROOT/scripts/sv0"
    "$ROOT/lib/shell/common.sh"
    "$ROOT/lib/sml/build-helpers.sh"
    "$ROOT/task/sv0vm-milestone-2/01-verify-setup.sh"
    "$ROOT/task/sv0vm-milestone-2/02-integration-test.sh"
    "$ROOT/task/sv0c-milestone-1/01-verify-sml-setup.sh"
    "$ROOT/task/sv0c-milestone-1/02-integration-test.sh"
    "$ROOT/task/sv0-toolchain-workspace/01-verify-submodules.sh"
    "$ROOT/task/sv0-mcp-milestone-0/01-verify-package.sh"
  )
  for f in "${fmt_targets[@]}"; do
    [[ -f "$f" ]] || continue
    bash -n "$f" || sv0_fail "bash -n failed: $f"
  done
  if command -v shfmt >/dev/null 2>&1; then
    local existing=()
    for f in "${fmt_targets[@]}"; do
      [[ -f "$f" ]] && existing+=("$f")
    done
    if ((${#existing[@]} > 0)); then
      shfmt -i 2 -w "${existing[@]}"
    fi
    sv0_ok "shfmt applied"
  else
    sv0_info "shfmt not installed; skipped write-format"
  fi
  sv0_ok "fmt-shell: bash syntax OK"
}

run_ci() {
  run_check
  run_test
  sv0_ok "ci: SML-only (check + full sv0 test harness) passed"
}

run_ci_all() {
  run_ci
  run_test_mcp
  sv0_ok "ci-all: SML ci + sv0-mcp (pytest when uv is available)"
}

run_repl() {
  require_sml
  mkdir -p "$SV0C/build/vm"
  local src="$SV0C/build/repl_line.sv0"
  echo "sv0 repl (bytecode VM). Enter an i32 expression (e.g. 2 + 2) or a println(\"...\") call." >&2
  echo "main's exit code is printed as the expression result. :q or EOF quits." >&2
  while true; do
    read -r -p "> " line || {
      echo >&2
      break
    }
    [[ -z "${line//[[:space:]]/}" ]] && continue
    case "$line" in
      :q | :quit) break ;;
    esac
    if [[ "$line" =~ ^[[:space:]]*println\( ]]; then
      local stmt="$line"
      [[ "$stmt" != *';' ]] && stmt="${stmt};"
      cat >"$src" <<EOF
fn main() -> unit {
  ${stmt}
}
EOF
    else
      cat >"$src" <<EOF
fn main() -> i32 {
  return (${line});
}
EOF
    fi
    local log
    log="$(mktemp)"
    if ! (cd "$SV0C" && echo "CM.make \"sources.cm\"; Main.main ((), [\"--target=vm\", \"build/repl_line.sv0\"]);" | sml >"$log" 2>&1); then
      echo "compile error:" >&2
      tail -20 "$log" >&2
      rm -f "$log"
      continue
    fi
    if grep -q 'Error:' "$log"; then
      echo "compile error:" >&2
      tail -20 "$log" >&2
      rm -f "$log"
      continue
    fi
    rm -f "$log"
    local sv0b="$SV0C/build/vm/repl_line.sv0b"
    if [[ ! -f "$sv0b" ]]; then
      echo "no bytecode emitted" >&2
      continue
    fi
    local out
    out="$(cd "$SV0VM" && SV0B="$sv0b" sml < scripts/run_sv0b.sml 2>&1)" || true
    local ev
    ev="$(echo "$out" | grep -E '^vm_exit:' | tail -1 | sed 's/^vm_exit://')"
    echo "$out" | awk '/^SV0VM_RUN_BEGIN$/ {p=1; next} /^vm_exit:/ {p=0; next} p && !/^val exitCode =/ {print}' || true
    if [[ -n "$ev" ]]; then
      echo "=> exit ${ev}" >&2
    fi
  done
}

cmd="${1:-}"
shift || true

case "$cmd" in
  check|build)
    run_check
    ;;
  test)
    run_test
    ;;
  test-mcp)
    run_test_mcp
    ;;
  doc)
    run_doc
    ;;
  doctest)
    run_doctests
    ;;
  fmt)
    run_fmt
    ;;
  fmt-shell)
    run_fmt_shell
    ;;
  rewrite-build)
    run_rewrite_build || exit 1
    ;;
  integration-vm)
    bash "$ROOT/task/sv0vm-milestone-2/02-integration-test.sh"
    ;;
  vm-compile)
    rel="${1:-}"
    if [[ -z "$rel" ]]; then usage; exit 1; fi
    (cd "$SV0C" && echo "CM.make \"sources.cm\"; Main.main ((), [\"--target=vm\", \"$rel\"]);" | sml)
    ;;
  vm-run)
    sv0b="${1:-}"
    if [[ -z "$sv0b" ]]; then usage; exit 1; fi
    (cd "$SV0VM" && SV0B="$sv0b" sml < scripts/run_sv0b.sml)
    ;;
  repl)
    run_repl
    ;;
  ci)
    run_ci
    ;;
  ci-all)
    run_ci_all
    ;;
  ""|-h|--help)
    usage
    exit 0
    ;;
  *)
    echo "sv0: unknown command: $cmd" >&2
    usage
    exit 1
    ;;
esac
